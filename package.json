{
  "name": "node-konfig",
  "private": true,
  "description": "Node Konfig monorepo",
  "workspaces": [
    "core",
    "loaders/*",
    "parsers/*",
    "internal"
  ],
  "type": "module",
  "scripts": {
    "build": "bun --filter '@willsoto/node-konfig-core' --filter '@node-konfig/internal' build && bun --filter '*' build",
    "changeset": "changeset",
    "changeset:status": "changeset status --since origin/main",
    "checkstyle": "oxfmt --check .",
    "clean": "bun --filter '*' clean",
    "docs:build": "vitepress build docs",
    "docs:dev": "vitepress dev docs",
    "docs:serve": "vitepress serve docs",
    "format": "oxfmt --write .",
    "lint": "oxlint --fix .",
    "prepare": "lefthook install",
    "publish": "changeset publish",
    "test": "bun --filter '*' test",
    "test:coverage": "bun --filter '*' test:coverage"
  },
  "devDependencies": {
    "@changesets/cli": "2.26.1",
    "@commitlint/cli": "17.6.5",
    "@commitlint/config-conventional": "17.6.5",
    "@types/node": "18.16.16",
    "@types/sinon": "10.0.15",
    "ava": "5.3.0",
    "c8": "7.14.0",
    "lefthook": "1.11.13",
    "oxfmt": "0.42.0",
    "oxlint": "1.57.0",
    "rimraf": "5.0.1",
    "sinon": "15.1.0",
    "ts-node": "10.9.1",
    "typescript": "5.0.4",
    "vitepress": "1.0.0-beta.1",
    "vue": "3.3.4"
  },
  "commitlint": {
    "extends": [
      "@commitlint/config-conventional"
    ]
  },
  "packageManager": "bun@1.3.8"
}

{
  "name": "node-konfig",
  "private": true,
  "description": "Node Konfig monorepo",
  "workspaces": [
    "core",
    "loaders/*",
    "parsers/*",
    "internal"
  ],
  "type": "module",
  "scripts": {
    "build": "bun --filter '@willsoto/node-konfig-core' --filter '@node-konfig/internal' build && bun --filter '*' build",
    "changeset": "changeset",
    "changeset:status": "changeset status --since origin/main",
    "checkstyle": "oxfmt --check .",
    "docs:build": "vitepress build docs",
    "docs:dev": "vitepress dev docs",
    "docs:serve": "vitepress serve docs",
    "format": "oxfmt --write .",
    "lint": "oxlint --fix .",
    "prepare": "lefthook install",
    "publish": "changeset publish",
    "test": "bun --filter '*' test",
    "test:coverage": "bun --filter '*' test:coverage"
  },
  "devDependencies": {
    "@changesets/cli": "2.30.0",
    "@commitlint/cli": "20.5.0",
    "@commitlint/config-conventional": "20.5.0",
    "@types/node": "25.6.0",
    "lefthook": "2.1.5",
    "oxfmt": "0.44.0",
    "oxlint": "1.60.0",
    "typescript": "6.0.2",
    "vitepress": "1.6.4",
    "vue": "3.5.32"
  },
  "commitlint": {
    "extends": [
      "@commitlint/config-conventional"
    ]
  },
  "packageManager": "bun@1.3.8"
}
